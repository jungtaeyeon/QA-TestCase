{
  "servers": {
    "figma": {
      "type": "http",
      "url": "https://mcp.figma.com/mcp",
      "headers": {
        "X-Figma-Token": "${env:FIGMA_API_KEY}"
      }
    },
    "testiny": {
      "type": "http",
      "url": "https://app.testiny.io/api/v1/mcp-server",
      "headers": {
        "Authorization": "Bearer ${env:TESTINY_API_KEY}"
      }
    }
  }
}
